# Normalize line endings: always LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Force binary for binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
