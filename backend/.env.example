# Script2Screen Backend — Environment Variables
# Copy this to .env and fill in your actual values.
# NEVER commit the real .env file — it is excluded by .gitignore.

FLASK_ENV=development
PORT=5000

# App Config
SECRET_KEY=your-secret-key-here

# Groq API — used for AI script generation (script_service.py)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Sarvam AI — used for script translation (translation_service.py)
# Get your key at https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# D-ID API — used for talking avatar video generation (video_service.py)
# Get your credentials at https://www.d-id.com
# DID_API_USER is the base64-encoded email from your D-ID account
DID_API_USER=your_did_api_user_base64_here
DID_API_SECRET=your_did_api_secret_here

# Cloudinary — used to host avatar images & audio for Replicate
# Get your credentials at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Replicate API — used for SadTalker video generation (video_service.py)
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here
